.tab-bar {
  position: fixed;
  bottom: 30rpx; /* 悬浮效果 */
  left: 30rpx;
  right: 30rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px); /* 磨砂玻璃 */
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-radius: 60rpx; /* 全圆角内嵌感 */
  box-shadow: 0 10rpx 40rpx rgba(27, 77, 62, 0.15); /* 使用湖水绿阴影 */
  z-index: 9999;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}
