.container {
  padding: 0;
  background-color: var(--bg-color);
  min-height: 100vh;
}

.decorative-bg {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.ink-blob {
  position: absolute;
  top: -100rpx;
  right: -50rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(125, 185, 182, 0.05) 0%, transparent 70%);
  filter: blur(40rpx);
}

.header-banner {
  padding: 80rpx 40rpx 40rpx 40rpx;
  position: relative;
  z-index: 10;
}

.banner-title {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--primary-color);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  font-family: serif;
}

.banner-sub {
  font-size: 24rpx;
  color: var(--text-light);
  letter-spacing: 2rpx;
  opacity: 0.8;
}

.records-list {
  padding: 0 40rpx 100rpx 40rpx;
  position: relative;
  z-index: 10;
  height: calc(100vh - 200rpx);
}

.record-card {
  margin-bottom: 40rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  padding: 40rpx;
  position: relative;
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  border: 1rpx solid rgba(125, 185, 182, 0.1);
  overflow: hidden;
}

.record-card:active {
  transform: scale(0.98);
  background: rgba(240, 247, 247, 0.9);
}

/* 宣纸书法感标记 */
.record-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(to bottom, var(--secondary-color), transparent);
  border-radius: 4rpx;
}

.record-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 24rpx;
  line-height: 1.4;
  font-family: serif;
}

.record-summary {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.8;
  margin-bottom: 32rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx dashed rgba(125, 185, 182, 0.2);
  padding-top: 24rpx;
}

.publish-date {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 1rpx;
}

.read-more {
  font-size: 24rpx;
  color: var(--secondary-color);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.loading-more, .no-more, .empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-light);
  font-size: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}
