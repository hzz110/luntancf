.container.detail-page {
  padding: 40rpx;
  background-color: #ffffff;
  min-height: 100vh;
}

.article-header {
  margin-bottom: 60rpx;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(125, 185, 182, 0.1);
}

.article-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-dark);
  line-height: 1.4;
  margin-bottom: 24rpx;
  font-family: serif;
}

.article-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: var(--text-light);
  letter-spacing: 1rpx;
}

.article-content {
  line-height: 1.8;
  color: var(--text-dark);
  font-size: 30rpx;
  padding-bottom: 120rpx;
}

/* 富文本样式优化 */
.rich-content img {
  max-width: 100%;
  border-radius: 12rpx;
  margin: 20rpx 0;
  display: block;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.rich-content h2, .rich-content h3 {
  color: var(--primary-color);
  font-weight: 600;
  margin: 40rpx 0 20rpx 0;
}

.rich-content blockquote {
  border-left: 8rpx solid var(--secondary-color);
  padding: 24rpx 32rpx;
  background: rgba(125, 185, 182, 0.05);
  margin: 32rpx 0;
  border-radius: 4rpx;
  font-style: italic;
  color: var(--text-light);
}

.article-footer {
  text-align: center;
  padding-bottom: 80rpx;
}

.footer-line {
  width: 100rpx;
  height: 4rpx;
  background-color: var(--accent-color);
  display: inline-block;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 4rpx;
  font-family: serif;
  opacity: 0.6;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: var(--text-light);
  font-size: 26rpx;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--secondary-color);
  border-top-color: transparent;
  border-radius: 50%;
  animation: rotate 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
