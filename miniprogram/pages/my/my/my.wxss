page {
  background-color: var(--bg-color);
}

.my-page {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 签到码区域：宣纸/书卷质感 */
.ticket-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  width: 100%;
}

.main-ticket-icon {
  width: 280rpx;
  height: 280rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  position: relative;
  box-shadow: 0 20rpx 40rpx rgba(27, 77, 62, 0.2);
}

.inner-ticket {
  width: 160rpx;
  height: 100rpx;
  background-color: #fffdf8; /* 宣纸色 */
  border: 1rpx solid rgba(125, 185, 182, 0.3);
  border-radius: 12rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.05);
}

.ticket-hole {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  top: 50%;
  transform: translateY(-50%);
}
.ticket-hole.left { left: -12rpx; }
.ticket-hole.right { right: -12rpx; }

.ticket-line {
  width: 2rpx;
  height: 60rpx;
  background-color: var(--secondary-color);
  opacity: 0.3;
}

.ticket-center {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx dashed var(--accent-color);
  border-radius: 50%;
}

.ticket-title {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  font-family: serif;
}

.ticket-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
  letter-spacing: 2rpx;
}

/* 胸卡保存区域：艺术画框感 */
.badge-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  width: 100%;
}

.badge-card {
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(125, 185, 182, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
}

.phone-mockup {
  width: 120rpx;
  height: 200rpx;
  background: linear-gradient(to bottom, #2c3e50, #1a252f);
  border-radius: 20rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.screen {
  width: 100rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 10rpx;
  box-sizing: border-box;
}

.screen-block {
  background: rgba(125, 185, 182, 0.4);
  border-radius: 6rpx;
  width: 100%;
}
.block-top { height: 20%; }
.block-mid { height: 40%; }
.block-bottom { height: 30%; }

.badge-tag {
  position: absolute;
  background: var(--accent-color);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  white-space: nowrap;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(212, 175, 55, 0.3);
}

.badge-hint {
  font-size: 24rpx;
  color: var(--text-light);
  letter-spacing: 1rpx;
}

/* 座位卡片区域：金色雅席 */
.seating-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 60rpx 6rpx 60rpx 6rpx;
  padding: 48rpx;
  border: 1rpx solid rgba(125, 185, 182, 0.1);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.02);
}

.seating-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(125, 185, 182, 0.1);
  padding-bottom: 24rpx;
}

.seating-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-color);
  font-family: serif;
}

.seating-desk {
  color: var(--accent-color);
  font-size: 32rpx;
  font-weight: 600;
}

.seating-mates-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.seating-mates-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.mate-pill {
  background-color: var(--bg-color);
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
  color: var(--text-dark);
  border: 1rpx solid rgba(125, 185, 182, 0.1);
}

.seating-guide {
  font-size: 26rpx;
  color: var(--secondary-color);
  display: flex;
  align-items: center;
  background: rgba(125, 185, 182, 0.05);
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
}

.guide-icon {
  margin-right: 12rpx;
}
