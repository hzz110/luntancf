.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: 180rpx; /* Custom TabBar Height */
  background-color: var(--bg-color);
}

/* Tabs */
.tab-header {
  display: flex;
  background-color: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  height: 110rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 0 40rpx;
  border-bottom: 1rpx solid rgba(125, 185, 182, 0.1);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 30rpx;
  color: var(--text-light);
  letter-spacing: 2rpx;
}

.tab-item.active .tab-text {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(to right, var(--secondary-color), var(--primary-color));
  border-radius: 10rpx; /* 像小鱼或水滴 */
}

/* Timeline */
.schedule-list {
  flex: 1;
  width: 100%;
}

.timeline-container {
  padding: 60rpx 40rpx 100rpx 40rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  margin-bottom: 60rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.time-col {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-right: 48rpx;
  position: relative;
}

.time-text {
  font-size: 34rpx;
  font-family: serif;
  color: var(--primary-color);
  font-weight: 600;
  line-height: 1.2;
}

.timeline-dot {
  position: absolute;
  right: -14rpx;
  top: 10rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background-color: #fff;
  border: 4rpx solid var(--secondary-color);
  box-shadow: 0 0 16rpx rgba(125, 185, 182, 0.3);
  z-index: 2;
}

.timeline-line {
  position: absolute;
  right: -1rpx;
  top: 40rpx;
  bottom: -70rpx;
  width: 2rpx;
  background: linear-gradient(to bottom, var(--secondary-color), transparent);
  opacity: 0.3;
  z-index: 1;
}

/* Non-highlighted Break Style */
.timeline-item.break .time-text {
  color: var(--text-light);
  font-weight: 400;
}

.timeline-item.break .timeline-dot {
  border-color: #dce3ed;
  box-shadow: none;
}

.timeline-item.break .content-col {
  background-color: transparent;
  box-shadow: none;
  border: 1rpx dashed #dce3ed;
  padding: 24rpx 40rpx;
  border-radius: 30rpx;
}

.timeline-item.break .content-title {
  color: var(--text-light);
  font-size: 28rpx;
  font-weight: 400;
}

/* Card Style */
.content-col {
  flex: 1;
  background: #ffffff;
  border-radius: 40rpx 4rpx 40rpx 4rpx; /* 写意有机形态 */
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.02);
  border: 1rpx solid rgba(125, 185, 182, 0.1);
  transition: all 0.3s ease;
}

.timeline-item.highlight .content-col {
  border-left: 8rpx solid var(--accent-color);
  background: linear-gradient(to bottom right, #ffffff, #fffdf8);
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.content-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-tag {
  font-size: 24rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
}

.meta-tag::before {
  content: "·";
  margin-right: 12rpx;
  font-weight: bold;
  color: var(--secondary-color);
}

/* Bottom Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(27, 77, 62, 0.4);
  backdrop-filter: blur(4rpx);
  z-index: 1000;
  animation: fadeIn 0.4s forwards;
}

.modal-box {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #ffffff;
  border-radius: 60rpx 60rpx 0 0;
  padding: 60rpx 40rpx 100rpx 40rpx;
  z-index: 1001;
  transform: translateY(100%);
  animation: slideUp 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.05);
}

@keyframes slideUp {
  0% { transform: translateY(100%); }
  100% { transform: translateY(0); }
}

@keyframes fadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary-color);
  flex: 1;
  line-height: 1.4;
  font-family: serif;
}

.close-btn {
  font-size: 48rpx;
  color: #bdc3c7;
  padding: 10rpx;
  margin-left: 20rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 32rpx;
}

.detail-label {
  min-width: 140rpx;
  color: var(--text-light);
  font-size: 28rpx;
}

.detail-value {
  flex: 1;
  color: var(--text-dark);
  font-size: 28rpx;
  font-weight: 500;
}

.detail-desc {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.desc-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-dark);
  line-height: 1.8;
  background-color: var(--bg-color);
  padding: 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(125, 185, 182, 0.1);
}

.modal-footer .btn-primary {
  width: 100%;
}
