<view class="container">
  <!-- Tabs -->
  <view class="tab-header">
    <view class="tab-item {{activeTab === 'main' ? 'active' : ''}}" bindtap="switchTab" data-tab="main">
      <text class="tab-text">晨曦主坛 (上午)</text>
      <view class="tab-line" wx:if="{{activeTab === 'main'}}"></view>
    </view>
    <view class="tab-item {{activeTab === 'sub' ? 'active' : ''}}" bindtap="switchTab" data-tab="sub">
      <text class="tab-text">翠屏分坛 (下午)</text>
      <view class="tab-line" wx:if="{{activeTab === 'sub'}}"></view>
    </view>
  </view>

  <!-- Timeline List -->
  <scroll-view class="schedule-list" scroll-y>
    <view class="timeline-container">
      <view class="timeline-item {{item.type}}" wx:for="{{currentList}}" wx:key="index" bindtap="showDetail" data-item="{{item}}">
        <view class="time-col">
          <text class="time-text">{{item.time}}</text>
          <view class="timeline-dot"></view>
          <view class="timeline-line" wx:if="{{index < currentList.length - 1}}"></view>
        </view>
        <view class="content-col">
          <view class="content-title">{{item.title}}</view>
          <view class="content-meta" wx:if="{{item.speaker || item.location}}">
             <view class="meta-tag" wx:if="{{item.speaker}}">{{item.speaker}}</view>
             <view class="meta-tag" wx:if="{{item.location}}">{{item.location}}</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 日程详情弹窗 Modal -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal-box" wx:if="{{showModal}}">
    <view class="modal-header">
      <view class="modal-title">{{selectedAgenda.time}} · {{selectedAgenda.title}}</view>
      <view class="close-btn" bindtap="closeModal">×</view>
    </view>
    <view class="modal-body">
      <view class="detail-row" wx:if="{{selectedAgenda.speaker}}">
        <text class="detail-label">分享嘉宾</text>
        <text class="detail-value">{{selectedAgenda.speaker}}</text>
      </view>
      <view class="detail-row" wx:if="{{selectedAgenda.location}}">
        <text class="detail-label">缘起地点</text>
        <text class="detail-value">{{selectedAgenda.location}}</text>
      </view>
      <view class="detail-desc">
        <text class="detail-label">内容亮点</text>
        <view class="desc-text">{{selectedAgenda.desc}}</view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-primary" bindtap="collectAgenda">收藏此议程</button>
    </view>
  </view>
</view>