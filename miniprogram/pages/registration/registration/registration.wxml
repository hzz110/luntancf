<view class="container">
  <!-- Type Switch: 身份选择 -->
  <view class="type-switch">
    <view class="switch-item {{type === 'alumni' ? 'active' : ''}}" bindtap="switchType" data-type="alumni">归园校友</view>
    <view class="switch-item {{type === 'enterprise' ? 'active' : ''}}" bindtap="switchType" data-type="enterprise">共建企业</view>
  </view>

  <scroll-view scroll-y class="form-container">
    <!-- 校友表单 -->
    <view class="form-card" wx:if="{{type === 'alumni'}}">
      <view class="form-title">基本信息 · 缘起交大</view>
      <view class="form-group">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <input class="form-input" placeholder="请输入真实姓名" data-field="name" bindinput="inputChange" />
      </view>
      <view class="form-group">
        <text class="form-label">入学年份 <text class="required">*</text></text>
        <input class="form-input" type="number" placeholder="如：1987" data-field="year" bindinput="inputChange" />
      </view>
      <view class="form-group">
        <text class="form-label">院系专业 <text class="required">*</text></text>
        <input class="form-input" placeholder="如：土木工程" data-field="major" bindinput="inputChange" />
      </view>
      <view class="form-group">
        <text class="form-label">当前单位及职务</text>
        <input class="form-input" placeholder="选填，现场交流使用" data-field="company" bindinput="inputChange" />
      </view>
      <view class="form-group">
        <text class="form-label">联系电话 <text class="required">*</text></text>
        <input class="form-input" type="number" placeholder="用于接收预约回执" data-field="phone" bindinput="inputChange" />
      </view>
      <view class="form-group row">
        <text class="form-label">需协助预订酒店（自理）</text>
        <switch color="#1B4D3E" data-field="hotel" bindchange="switchChange" />
      </view>
    </view>

    <!-- 企业表单 -->
    <view class="form-card" wx:if="{{type === 'enterprise'}}">
      <view class="form-title">企业信息 · 产教共荣</view>
      <view class="form-group">
        <text class="form-label">企业名称 <text class="required">*</text></text>
        <input class="form-input" placeholder="请输入企业全称" data-field="entName" bindinput="inputChange" />
      </view>
      <view class="form-group">
        <text class="form-label">所属行业 <text class="required">*</text></text>
        <input class="form-input" placeholder="如：轨道交通、智能制造" data-field="entIndustry" bindinput="inputChange" />
      </view>
      <view class="form-group">
        <text class="form-label">委派参会人数 <text class="required">*</text></text>
        <input class="form-input" type="number" value="1" placeholder="1-5人" data-field="entCount" bindinput="inputChange" />
      </view>
      <view class="form-group row">
        <text class="form-label">现场展位/宣传册预留</text>
        <switch color="#1B4D3E" data-field="entBooth" bindchange="switchChange" />
      </view>
      <view class="form-group">
        <text class="form-label">开票信息</text>
        <input class="form-input" placeholder="选填，税号及抬头" data-field="entInvoice" bindinput="inputChange" />
      </view>
    </view>
    
    <view class="submit-btn-wrap">
      <button class="btn-primary form-submit-btn" bindtap="submitForm">确认信息并预约</button>
      <view class="form-note">注：相关费用将全部用于论坛物料与茶歇</view>
    </view>
  </scroll-view>

  <!-- 模拟支付弹窗 -->
  <view class="modal-mask" wx:if="{{showPayment}}" bindtap="cancelPayment"></view>
  <view class="payment-modal" wx:if="{{showPayment}}">
    <view class="pay-title">预约确认</view>
    <view class="pay-amount">￥99.00</view>
    <view class="pay-desc">收款方：第三届交大论坛组委会</view>
    
    <button class="pay-btn" loading="{{isPaying}}" bindtap="confirmPayment">
      {{isPaying ? '正在开启缘分...' : '确认预约'}}
    </button>
  </view>
</view>