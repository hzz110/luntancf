.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: var(--bg-color);
  padding-bottom: 180rpx;
}

.type-switch {
  display: flex;
  margin: 40rpx 40rpx;
  background-color: rgba(125, 185, 182, 0.1);
  border-radius: 60rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(125, 185, 182, 0.1);
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-light);
  border-radius: 50rpx;
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  letter-spacing: 2rpx;
}

.switch-item.active {
  background-color: #ffffff;
  color: var(--primary-color);
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(27, 77, 62, 0.1);
}

.form-container {
  flex: 1;
  padding: 0 40rpx 60rpx 40rpx;
}

.form-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 60rpx 6rpx 60rpx 6rpx; /* 写意有机形态 */
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.02);
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(125, 185, 182, 0.1);
}

.form-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  font-family: serif;
}

.form-title::before {
  content: "";
  width: 8rpx;
  height: 32rpx;
  background: var(--accent-color);
  margin-right: 16rpx;
  border-radius: 4rpx;
}

.form-group {
  margin-bottom: 48rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-group.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-dark);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-group.row .form-label {
  margin-bottom: 0;
}

.required {
  color: var(--accent-color);
  margin-left: 8rpx;
}

.form-input {
  width: 100%;
  height: 90rpx;
  background-color: rgba(125, 185, 182, 0.03);
  border-bottom: 2rpx solid rgba(125, 185, 182, 0.1); /* 写意风去边框留底线 */
  padding: 0 10rpx;
  font-size: 30rpx;
  color: var(--text-dark);
  box-sizing: border-box;
  transition: all 0.3s;
}

.form-input:focus {
  border-bottom-color: var(--secondary-color);
  background-color: rgba(125, 185, 182, 0.06);
}

.submit-btn-wrap {
  text-align: center;
  padding: 20rpx 0 80rpx 0;
}

.form-submit-btn {
  width: 100%;
  box-shadow: 0 12rpx 30rpx rgba(27, 77, 62, 0.2);
}

.form-note {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 32rpx;
  letter-spacing: 1rpx;
}

/* Payment Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(27, 77, 62, 0.4);
  backdrop-filter: blur(4rpx);
  z-index: 1000;
  animation: fadeIn 0.4s forwards;
}

.payment-modal {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #ffffff;
  border-radius: 60rpx 60rpx 0 0;
  padding: 80rpx 60rpx 120rpx 60rpx;
  z-index: 1001;
  text-align: center;
  animation: slideUp 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}

.pay-title {
  font-size: 30rpx;
  color: var(--text-light);
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

.pay-amount {
  font-size: 80rpx;
  font-weight: 600;
  font-family: "PingFang SC", sans-serif;
  color: var(--text-dark);
  margin-bottom: 20rpx;
}

.pay-desc {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 80rpx;
}

.pay-btn {
  background: linear-gradient(135deg, #07c160, #059d4d); /* 保持微信绿但增加渐变 */
  color: #ffffff;
  width: 100%;
  border-radius: 50rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.2);
}

@keyframes slideUp {
  0% { transform: translateY(100%); }
  100% { transform: translateY(0); }
}

@keyframes fadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}
