.container {
  padding: 32rpx;
  background-color: var(--bg-color);
  min-height: 100vh;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}
.main-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
}
.sub-title {
  font-size: 26rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}
.find-btn {
  background-color: #ffffff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  line-height: 64rpx;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.waterfall {
  column-count: 2;
  column-gap: 20rpx;
}
.photo-card {
  break-inside: avoid;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.photo-img {
  width: 100%;
  display: block;
}
.photo-info {
  padding: 16rpx;
}
.photo-time {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 4rpx;
}
.photo-desc {
  font-size: 26rpx;
  color: var(--text-dark);
}
