<view class="container">
  <view class="header">
    <view class="title-wrap">
      <view class="main-title">精彩瞬间</view>
      <view class="sub-title">照片流实时更新</view>
    </view>
    <button class="find-btn" bindtap="findMe">
      <text>🔍</text> 找自己
    </button>
  </view>
  
  <view class="waterfall">
    <view class="photo-card" wx:for="{{photos}}" wx:key="id" bindtap="preview" data-url="{{item.url}}">
      <image src="{{item.url}}" mode="widthFix" class="photo-img"></image>
      <view class="photo-info">
        <text class="photo-time">{{item.time}}</text>
        <text class="photo-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>
</view>